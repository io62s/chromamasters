  {
    "id": "giorgione-the-tempest",
    "title": "The Tempest",
    "artist": "Giorgione",
    "year": 1508,
    "medium": "Oil on canvas",
    "dimensions": "82 cm × 73 cm",
    "location": "Gallerie dell'Accademia, Venice",
    "description": "One of the most enigmatic paintings in Western art, The Tempest depicts a soldier and a nursing woman in a lush landscape as a bolt of lightning splits a stormy sky above a distant town. No convincing interpretation of the subject has ever been agreed upon, yet the painting's atmospheric unity — the way light, color, and mood merge into a single poetic vision — marks it as a revolutionary moment in the history of landscape painting.",
    "image": "/paintings/giorgione-the-tempest.jpg",
    "imageCredit": "Wikimedia Commons, Public Domain",
    "movementId": "renaissance",
    "colors": [
