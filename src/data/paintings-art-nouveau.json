  {
    "id": "mucha-slav-epic",
    "title": "The Slav Epic: Slavs in Their Original Homeland",
    "artist": "Alphonse Mucha",
    "year": 1912,
    "medium": "Egg tempera and oil on canvas",
    "dimensions": "610 cm × 810 cm",
    "location": "National Gallery, Prague",
    "description": "The first canvas of Mucha's monumental twenty-painting Slav Epic cycle depicts the ancient Slavic people sheltering from marauding tribes. The ethereal, dreamlike quality and vast scale mark a dramatic departure from his decorative poster work toward epic historical painting.",
