  {
    "id": "waterhouse-echo-narcissus",
    "title": "Echo and Narcissus",
    "artist": "John William Waterhouse",
    "year": 1903,
    "medium": "Oil on canvas",
    "dimensions": "109.2 cm × 189.2 cm",
    "location": "Walker Art Gallery, Liverpool",
    "description": "Waterhouse depicts the tragic myth of Echo, who can only repeat the last words spoken to her, watching helplessly as Narcissus falls in love with his own reflection. The woodland setting with its pool of dark water and the emotional distance between the two figures tells the story with subtle poignancy.",
    "image": "/paintings/waterhouse-echo-narcissus.jpg",
    "imageCredit": "Wikimedia Commons, Public Domain",
    "movementId": "pre-raphaelite",
