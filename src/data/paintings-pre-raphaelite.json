  {
    "id": "waterhouse-lady-of-shalott",
    "title": "The Lady of Shalott",
    "artist": "John William Waterhouse",
    "year": 1888,
    "medium": "Oil on canvas",
    "dimensions": "153 cm × 200 cm",
    "location": "Tate Britain, London",
    "description": "Waterhouse depicts the climactic moment from Tennyson's poem when the Lady of Shalott sets herself adrift in a boat to die, having looked directly at Sir Lancelot. Her expression of resigned despair, the autumnal riverscape, and the tapestry trailing from the boat create an image of haunting romantic tragedy.",
    "image": "/paintings/waterhouse-lady-of-shalott.jpg",
    "imageCredit": "Wikimedia Commons, Public Domain",
    "movementId": "pre-raphaelite",
