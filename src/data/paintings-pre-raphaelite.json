  {
    "id": "burne-jones-cophetua",
    "title": "King Cophetua and the Beggar Maid",
    "artist": "Edward Burne-Jones",
    "year": 1884,
    "medium": "Oil on canvas",
    "dimensions": "293.4 cm × 135.9 cm",
    "location": "Tate Britain, London",
    "description": "Based on an Elizabethan ballad, the painting shows an African king who has fallen in love with a beggar maid. Burne-Jones reverses the expected power dynamic — the maid sits elevated above the kneeling king, her simple beauty transcending his worldly power in a meditation on the sovereignty of love.",
    "image": "/paintings/burne-jones-cophetua.jpg",
    "imageCredit": "Wikimedia Commons, Public Domain",
    "movementId": "pre-raphaelite",
