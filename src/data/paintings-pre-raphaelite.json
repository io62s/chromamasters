  {
    "id": "millais-blind-girl",
    "title": "The Blind Girl",
    "artist": "John Everett Millais",
    "year": 1856,
    "medium": "Oil on canvas",
    "dimensions": "82.6 cm × 62.2 cm",
    "location": "Birmingham Museum and Art Gallery",
    "description": "A blind girl sits on a grassy roadside after a rainstorm, a double rainbow arching behind her that she will never see. The painting's poignant contrast between the girl's darkness and the luminous landscape around her makes it one of the most emotionally powerful Pre-Raphaelite works.",
    "image": "/paintings/millais-blind-girl.jpg",
    "imageCredit": "Wikimedia Commons, Public Domain",
